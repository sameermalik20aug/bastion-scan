# Bastion backend configuration.
# Copy to `.env` for local runs, or set these as environment variables on your
# host (Railway / Fly / etc.). All keys are prefixed BASTION_.
#
# IMPORTANT: there is NO Anthropic API key here. Bastion is bring-your-own-key:
# the user supplies their Anthropic key in the browser, and it travels to the
# backend in the per-request `X-Anthropic-Key` header for that one request only.
# It is never read from the server environment, never logged, never stored.

# Browser origin(s) allowed to call the API, comma-separated. NEVER use "*" —
# requests carry the BYOK key in a header, so only trusted frontends may call.
# Production example: https://bastion-scan.vercel.app
BASTION_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Send the HSTS header (forces browsers to use HTTPS). Keep true in production
# where TLS terminates at the platform edge; "false" for plain-HTTP localhost.
BASTION_HSTS_ENABLED=true

# Verbose debug mode. Leave false in production.
BASTION_DEBUG=false
